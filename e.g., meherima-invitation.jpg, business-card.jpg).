<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Afsana Mimi – Portfolio</title>
  <style>
    body {
      font-family: 'Poppins', sans-serif;
      margin: 0;
      padding: 0;
      background: #fdfdfd;
      color: #333;
    }
    header {
      background: #7A3FF2;
      color: white;
      padding: 20px;
      text-align: center;
    }
    nav a {
      color: white;
      margin: 0 15px;
      text-decoration: none;
      font-weight: bold;
    }
    section {
      padding: 40px;
      max-width: 1200px;
      margin: auto;
    }
    h2 {
      color: #7A3FF2;
      border-bottom: 2px solid #D4AF37;
      padding-bottom: 5px;
    }
    /* Portfolio Grid */
    .portfolio-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 20px;
    }
    .portfolio-item {
      background: #fff;
      border: 1px solid #ddd;
      padding: 15px;
      text-align: center;
      box-shadow: 0 2px 5px rgba(0,0,0,0.1);
      transition: transform 0.2s ease;
      cursor: pointer;
    }
    .portfolio-item:hover {
      transform: scale(1.03);
    }
    .portfolio-item img {
      max-width: 100%;
      height: auto;
      border-radius: 5px;
    }
    /* Lightbox */
    .lightbox {
      display: none;
      position: fixed;
      z-index: 999;
      padding-top: 60px;
      left: 0;
      top: 0;
      width: 100%;
      height: 100%;
      overflow: auto;
      background-color: rgba(0,0,0,0.9);
    }
    .lightbox img {
      margin: auto;
      display: block;
      max-width: 80%;
      max-height: 80%;
    }
    .close {
      position: absolute;
      top: 20px;
      right: 35px;
      color: #fff;
      font-size: 40px;
      font-weight: bold;
      cursor: pointer;
    }
  </style>
</head>
<body>

<header>
  <h1>Afsana Mimi</h1>
  <p>Marketing Executive & Graphic Designer</p>
  <nav>
    <a href="#about">About</a>
    <a href="#portfolio">Portfolio</a>
    <a href="#resume">Resume</a>
    <a href="#contact">Contact</a>
  </nav>
</header>

<section id="portfolio">
  <h2>Portfolio Showcase</h2>
  <div class="portfolio-grid">
    <div class="portfolio-item">
      <img src="images/meherima-invitation.jpg" alt="Meherima Fashion Invitation">
      <p>Meherima Fashion Ltd – Grand Opening Invitation</p>
    </div>
    <div class="portfolio-item">
      <img src="images/meherima-catalog.jpg" alt="Fashion Catalog">
      <p>2021 Collection Catalog & Canva Designs</p>
    </div>
    <div class="portfolio-item">
      <img src="images/construction-branding.jpg" alt="Construction Branding">
      <p>M/S & MTT Construction – Branding & Campaigns</p>
    </div>
    <div class="portfolio-item">
      <img src="images/haldi-invitation.jpg" alt="Haldi Ceremony Invitation">
      <p>Haldi Ceremony Invitation</p>
    </div>
    <div class="portfolio-item">
      <img src="images/business-card.jpg" alt="Business Card">
      <p>MS Showrav Enterprise – Business Card Design</p>
    </div>
  </div>
</section>

<!-- Lightbox -->
<div id="lightbox" class="lightbox">
  <span class="close">&times;</span>
  <img id="lightbox-img" src="" alt="">
</div>

<footer>
  <p>© 2026 Afsana Mimi | Designed with Elegance & Confidence</p>
</footer>

<script>
  // Lightbox functionality
  const lightbox = document.getElementById('lightbox');
  const lightboxImg = document.getElementById('lightbox-img');
  const closeBtn = document.querySelector('.close');

  document.querySelectorAll('.portfolio-item img').forEach(img => {
    img.addEventListener('click', () => {
      lightbox.style.display = 'block';
      lightboxImg.src = img.src;
      lightboxImg.alt = img.alt;
    });
  });

  closeBtn.addEventListener('click', () => {
    lightbox.style.display = 'none';
  });

  window.addEventListener('click', (e) => {
    if (e.target === lightbox) {
      lightbox.style.display = 'none';
    }
  });
</script>

</body>
</html>
